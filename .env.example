# ==========================================
# MẪU BIẾN MÔI TRƯỜNG (Template)
# Dùng để minh họa cho Server Production hoặc cho Dev mới clone dự án.
# File này CÓ ĐƯỢC LƯU thẳng lên Github (.env.example)
# ==========================================

# 1. Database Variables (PostgreSQL)
DB_NAME=cmms_db
DB_USER=root
DB_PASSWORD=your_secure_password_here

# 2. API Backend / Security Variables
NODE_ENV=production
PORT=3000
JWT_SECRET=your_strong_production_secret_key
JWT_EXPIRATION=7d

# 3. Microservices Variables (Redis)
REDIS_HOST=localhost
REDIS_PORT=6379

# 4. Frontend Web/Cors API Variable
CORS_ORIGIN=http://your_vps_domain.com
VITE_API_URL=http://your_vps_domain.com/api
